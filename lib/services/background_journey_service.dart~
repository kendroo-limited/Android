import 'package:background_location_tracker/background_location_tracker.dart';
import 'package:flutter/foundation.dart';


class BackgroundJourneyService {
  static const String _prefsBaseUrl = 'bg_baseUrl';
  static const String _prefsCookie = 'bg_cookie';
  static const String _prefsFieldForceId = 'bg_fieldForceId';
  static const String _prefsEnabled = 'bg_enabled';
  static const String _prefsLastSentMs = 'bg_last_sent_ms';

  static bool _isSending = false;

  static Future<void> start({
    required String baseUrl,
    required String cookie,
    required int fieldForceId,
  }) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(_prefsBaseUrl, baseUrl);
    await prefs.setString(_prefsCookie, cookie);
    await prefs.setInt(_prefsFieldForceId, fieldForceId);
    await prefs.setBool(_prefsEnabled, true);

    await BackgroundLocationTrackerManager.startTracking();
    debugPrint('BackgroundJourneyService started');
  }

  static Future<void> stop() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setBool(_prefsEnabled, false);

    await BackgroundLocationTrackerManager.stopTracking();
    debugPrint('BackgroundJourneyService stopped');
  }

  static Future<void> handleBackgroundUpdate(
      BackgroundLocationUpdateData data,
      ) async {
    if (_isSending) return;
    _isSending = true;

    try {
      final prefs = await SharedPreferences.getInstance();

      final enabled = prefs.getBool(_prefsEnabled) ?? false;
      final baseUrl = prefs.getString(_prefsBaseUrl);
      final cookie = prefs.getString(_prefsCookie);
      final fieldForceId = prefs.getInt(_prefsFieldForceId);

      if (!enabled || baseUrl == null || cookie == null || fieldForceId == null) {
        debugPrint('BG skipped because config missing');
        return;
      }

      final lat = data.lat;
      final lng = data.lon;

      if (lat == null || lng == null) {
        debugPrint('BG location is null');
        return;
      }

      // Only send once every 15 minutes.
      final nowMs = DateTime.now().millisecondsSinceEpoch;
      final lastSentMs = prefs.getInt(_prefsLastSentMs) ?? 0;

      if (nowMs - lastSentMs < const Duration(minutes: 15).inMilliseconds) {
        debugPrint('BG throttled, not sending yet');
        return;
      }

      debugPrint('BG sending location: $lat, $lng');

      final payload = {
        "jsonrpc": "2.0",
        "method": "call",
        "params": {
          "model": "kio.field.force.journey",
          "method": "create",

          "args": [
            {
              "field_force_id": fieldForceId,

              "latitude": lat,
              "longitude": lng,
              "location": "Lat:${lat.toStringAsFixed(5)}, Lng:${lng.toStringAsFixed(5)}",
              "journey_time": DateTime.now().toIso8601String().replaceAll('T', ' ').substring(0, 19),
            }
          ],
          // Leave kwargs empty
          "kwargs": {},
        },
        "id": DateTime.now().millisecondsSinceEpoch,
      };

      final response = await http.post(
        Uri.parse('$baseUrl/web/dataset/call_kw'),
        headers: {
          "Content-Type": "application/json",
          "Cookie": cookie,
        },
        body: jsonEncode(payload),
      );

      debugPrint("BG API status: ${response.statusCode}");
      debugPrint("BG API body: ${response.body}");

      if (response.statusCode != 200) {
        throw Exception('HTTP ${response.statusCode}: ${response.body}');
      }

      final body = jsonDecode(response.body);
      if (body is Map && body['error'] != null) {
        throw Exception(body['error'].toString());
      }

      await prefs.setInt(_prefsLastSentMs, nowMs);
      debugPrint('BG journey line sent successfully');
    } catch (e, s) {
      debugPrint('Background sync error: $e');
      debugPrint('$s');
    } finally {
      _isSending = false;
    }
  }
}

